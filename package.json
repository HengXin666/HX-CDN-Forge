{
  "name": "hx-cdn-forge",
  "version": "1.1.0",
  "description": "A React + TypeScript CDN node selector with latency testing and smart switching for GitHub resources",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/index.css"
  },

  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "cdn",
    "cdn-selector",
    "cdn-forge",
    "latency-test",
    "github-cdn",
    "jsdelivr",
    "react",
    "typescript",
    "cdn-switcher",
    "cdn-failover",
    "performance",
    "china-friendly"
  ],
  "author": "HX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HX-UserName/hx-cdn-forge"
  },
  "bugs": {
    "url": "https://github.com/HX-UserName/hx-cdn-forge/issues"
  },
  "homepage": "https://github.com/HX-UserName/hx-cdn-forge#readme",
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^29.7.0",
    "parcel": "^2.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ]
}
